{
  "name": "baseballgame",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=baseballgame",
    "db:migrate": "wrangler d1 execute baseballgame-db --file=./functions/db/schema.sql",
    "db:seed": "wrangler d1 execute baseballgame-db --file=./functions/db/seed.sql"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "bcryptjs": "^2.4.3",
    "@tsndr/cloudflare-worker-jwt": "^2.5.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240512.0",
    "wrangler": "^3.57.0",
    "typescript": "^5.4.0",
    "@types/bcryptjs": "^2.4.6",
    "vite": "^5.2.0"
  }
}
